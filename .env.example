# PostgreSQL (obrigatório). Exemplos:
# Local: postgresql://USER:PASSWORD@localhost:5432/strangeflix?schema=public
# Neon:  postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/strangeflix?schema=public"

# URL canônica do site (Open Graph, sitemap, canonical). Na Vercel costuma ser opcional se usar VERCEL_URL.
# Ex.: https://strangeflix.vercel.app ou o teu domínio customizado
# NEXT_PUBLIC_SITE_URL="https://example.com"
